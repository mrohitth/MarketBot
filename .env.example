# Alpha Vantage API Key (free at alphavantage.co)
ALPHA_VANTAGE_KEY=YOUR_KEY_HERE

# WhatsApp Webhook Secret (from OpenClaw config)
WHATSAPP_WEBHOOK_SECRET=YOUR_SECRET_HERE

# Discover CSV path (default: data/discover-transactions.csv)
DISCOVER_CSV_PATH=./data/discover-transactions.csv

# Monthly net income (for savings rate calculation)
MONTHLY_NET_INCOME=8500

# Portfolio total value (for cash target calculation)
PORTFOLIO_TOTAL=850000